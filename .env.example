# Копируйте в .env и подставьте свои значения.
# .env не коммитится (см. .gitignore).

# Strapi CMS (если задано — услуги и галерея подтягиваются из Strapi)
# Локально: http://localhost:1337
# На VPS: https://api.yourdomain.com
# STRAPI_URL=http://localhost:1337
# Токен из Settings → API Tokens (тип Read-only) — нужен, если нет роли Public
# STRAPI_API_TOKEN=

# Telegram-бот для уведомлений о записях (API /booking)
# TELEGRAM_TOKEN=
# TELEGRAM_CHAT_ID=
