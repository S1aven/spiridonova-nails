{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Услуга",
    "description": "Услуги салона (маникюр, педикюр, дизайн)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "string"
    },
    "longDescription": {
      "type": "text"
    },
    "price": {
      "type": "integer",
      "required": true
    },
    "oldPrice": {
      "type": "integer"
    },
    "duration": {
      "type": "integer",
      "required": true,
      "description": "Длительность в минутах"
    },
    "category": {
      "type": "enumeration",
      "enum": ["manicure", "pedicure", "other"],
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "features": {
      "type": "json",
      "description": "Массив строк — пункты описания услуги"
    },
    "isPopular": {
      "type": "boolean",
      "default": false
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    }
  }
}
